# Hotjar (session recordings) — copied into the client bundle at build time.
# Get your Site ID from Hotjar → Sites → Tracking code.
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_HOTJAR_SV=6

# Crisp live chat. Leave empty to disable.
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Mapbox public token (pk.*) — powers the free Route Planner tool at /tools/route-planner.
# Same public token used by the app; safe to expose client-side.
NEXT_PUBLIC_MAPBOX_TOKEN=
