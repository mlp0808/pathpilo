{
  "name": "vevago",
  "version": "1.0.0",
  "description": "Client management system for service companies",
  "main": "server.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:3002": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3004",
    "lint": "next lint",
    "dev:server": "node server.js",
    "dev:marketing": "cd marketing && npm run dev",
    "build:marketing": "cd marketing && npm run build",
    "dev:fullstack": "concurrently \"npm run dev:api-server\" \"npm run dev\" \"npm run dev:marketing\"",
    "dev:api-server": "cd api-server && node server.js",
    "clean": "node -e \"const fs=require('fs'); const path=require('path'); const rm=(p)=>fs.rmSync(p,{recursive:true,force:true}); ['.next'].forEach(d=>{const p=path.join(process.cwd(),d); if(fs.existsSync(p)) rm(p);}); console.log('cleaned .next');\"",
    "db:setup": "node setup-database.js --seed",
    "db:reset": "node setup-database.js --reset --seed",
    "generate-test-data": "node generate-test-data.js",
    "i18n:check": "node scripts/check-i18n-keys.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@internationalized/date": "^3.11.0",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mapbox-gl": "^3.20.0",
    "next": "^15.5.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-aria-components": "^1.15.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
    "react-stately": "^3.44.0",
    "recharts": "^3.7.0",
    "resend": "^6.7.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.21",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.7",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "saas",
    "client-management",
    "service-companies"
  ],
  "author": "PathPilo Team",
  "license": "MIT"
}
