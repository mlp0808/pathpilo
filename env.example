# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/vevago_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vevago_dev
DB_USER=your_username
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Server Configuration
# Express API port (frontend is Next.js, usually on 3000 in dev / 3002 in prod)
PORT=3003
NODE_ENV=development

# Optional (frontend) - override API base URL in the browser
# NEXT_PUBLIC_API_URL=http://localhost:3003

# Hotjar (frontend analytics / session recordings)
# Enable by setting your Site ID from Hotjar.
# Example:
# NEXT_PUBLIC_HOTJAR_ID=1234567
# NEXT_PUBLIC_HOTJAR_SV=6

# Email Configuration (recommended: Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: SMTP Configuration (fallback)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Company Configuration
COMPANY_NAME=PathPilo
SUPPORT_EMAIL=support@vevago.com

# ---- Production (server) ----
# NODE_ENV=production
# PORT=3003
# NEXT_PUBLIC_API_URL=   (leave empty if frontend is served with /api proxied to same host)
# FRONTEND_URL=https://app.pathpilo.com
# ALLOWED_ORIGINS=https://app.pathpilo.com

