# Copy this file to ".env" (same folder) when testing on your phone at home.
# You do NOT need this file for Google Play — the production build uses app.pathpilo.com automatically.

# Your computer's IP on Wi‑Fi (ipconfig in PowerShell → IPv4), plus ports from npm run dev
EXPO_PUBLIC_API_URL=http://192.168.1.52:8000/api
EXPO_PUBLIC_WEB_URL=http://192.168.1.52:3000
