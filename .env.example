# ============================================
# PathPilo Environment Variables
# ============================================
# Copy to .env and fill in values.
# NEVER commit .env to git.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pathpilo
DB_USER=pathpilo
DB_PASSWORD=

# --- Authentication ---
JWT_SECRET=

# --- Super Admin ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Email (Resend) ---
RESEND_API_KEY=
FROM_EMAIL=noreply@pathpilo.com
FROM_NAME=PathPilo

# --- Frontend ---
FRONTEND_URL=https://pathpilo.com
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_HOTJAR_SV=

# --- Server ---
API_PORT=3005
PORT=3005
NODE_ENV=production

# --- CORS ---
ALLOWED_ORIGINS=https://pathpilo.com,https://www.pathpilo.com,https://app.pathpilo.com
