# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vevago_local
DB_USER=vevago_local
DB_PASSWORD=password123

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Optional - for notifications and invoices)
# Option A: Resend (API, not SMTP – get a key at https://resend.com)
RESEND_API_KEY=your-resend-api-key

# Option B: SMTP (Gmail, SendGrid, your provider, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# From address (required for delivery; Resend may require a verified domain)
FROM_EMAIL=noreply@yourapp.com
# Sender display name (e.g. "PathPilo" – shows as the sender name in inbox)
FROM_NAME=PathPilo

FRONTEND_URL=http://localhost:3000

# Server Configuration
API_PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ---- Production (app.pathpilo.com) ----
# FRONTEND_URL=https://app.pathpilo.com
# ALLOWED_ORIGINS=https://app.pathpilo.com
# API_PORT=3003

# Future Features
# GOOGLE_MAPS_API_KEY=your-google-maps-key
# TWILIO_SID=your-twilio-sid
# TWILIO_TOKEN=your-twilio-token
# STRIPE_SECRET_KEY=your-stripe-key
